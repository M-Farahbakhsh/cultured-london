# Copy this file to .env.local and fill in your values

# Supabase — get these from supabase.com > your project > Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Eventbrite — get from eventbrite.com/platform
EVENTBRITE_API_KEY=your-eventbrite-key

# Ticketmaster — get from developer.ticketmaster.com
TICKETMASTER_API_KEY=your-ticketmaster-key

# Meetup — get from secure.meetup.com/meetup_api/key
MEETUP_API_KEY=your-meetup-key

# Bandsintown — get from artists.bandsintown.com/api
BANDSINTOWN_APP_ID=your-app-id
